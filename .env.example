# Vercel only — required when Deployment Protection is enabled.
# Create in: Project Settings → Deployment Protection → Protection Bypass for Automation
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Slide image previews on Vercel (no PowerPoint/LibreOffice in serverless).
# Get a free secret at https://www.convertapi.com (Authentication → API Secret).
# Without this, deployed previews fall back to geometry-only placeholder boxes.
# CONVERTAPI_SECRET=
